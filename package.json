{
	"name": "visible-cursor",
	"version": "1.0.15",
	"description": "Flash cursor position after big moves and cursor jumps - block cursor with smart highlighting",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:browser": "playwright test"
	},
	"keywords": [
		"cursor",
		"cues",
		"navigation",
		"visibility"
	],
	"author": "Scott Otterson",
	"license": "MIT",
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@types/node": "^22.0.0",
		"@typescript-eslint/eslint-plugin": "^5.2.0",
		"@typescript-eslint/parser": "^5.2.0",
		"@vitest/coverage-v8": "^4.0.18",
		"builtin-modules": "^3.2.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"playwright": "^1.59.1",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
